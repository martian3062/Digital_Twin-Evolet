# ==========================================
# MedGenie: Digital Twin Healthcare System
# Environment Configuration
# ==========================================

# --- Django Backend ---
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
DATABASE_URL=sqlite:///db.sqlite3
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-key

# --- JWT ---
JWT_SECRET_KEY=your-jwt-secret
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# --- Google Fit ---
GOOGLE_FIT_CLIENT_ID=your-client-id
GOOGLE_FIT_CLIENT_SECRET=your-client-secret
GOOGLE_FIT_REDIRECT_URI=http://localhost:8000/api/googlefit/callback

# --- AI Engine ---
AI_ENGINE_URL=http://localhost:8100
PINECONE_API_KEY=your-pinecone-key
PINECONE_ENVIRONMENT=your-environment

# --- WebRTC / LiveKit ---
LIVEKIT_API_KEY=your-livekit-key
LIVEKIT_API_SECRET=your-livekit-secret
LIVEKIT_URL=ws://localhost:7880

# --- Twilio (Alerts) ---
TWILIO_ACCOUNT_SID=your-sid
TWILIO_AUTH_TOKEN=your-token
TWILIO_PHONE_NUMBER=+1234567890

# --- Web3 / Blockchain ---
POLYGON_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/your-key
QUICKNODE_RPC_URL=https://your-quicknode-endpoint
PRIVATE_KEY=your-wallet-private-key
IPFS_API_URL=https://ipfs.infura.io:5001
IPFS_PROJECT_ID=your-infura-project-id
IPFS_PROJECT_SECRET=your-infura-secret

# --- Ceramic ---
CERAMIC_NODE_URL=https://ceramic-clay.3boxlabs.com

# --- Voice AI ---
WHISPER_MODEL_SIZE=base
COQUI_MODEL_NAME=tts_models/en/ljspeech/tacotron2-DDC

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
